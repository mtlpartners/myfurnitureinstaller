---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Connect With Professional Installers | Contact My Furniture Installer"
  description="Connect with professional furniture installers and designers. Installation, layout planning, and coordination services."
>
  <section class="page-hero">
    <div class="container">
      <h1>Get Connected</h1>
      <p>Connect with professional installers and designers. We handle installation, layout planning, and coordination—so you've got a guy.</p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-form-wrapper">
          <div class="form-header">
            <h2>Tell Us About Your Project</h2>
            <p>Fill out the form below and we'll connect you with the right installer for your needs. No sales pitch, just solutions.</p>
          </div>
          <form id="contact-form" class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Your Name *</label>
                <input type="text" id="name" name="name" required placeholder="John Smith" />
              </div>
              <div class="form-group">
                <label for="company">Company *</label>
                <input type="text" id="company" name="company" required placeholder="Acme Corp" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="john@acmecorp.com" />
              </div>
              <div class="form-group">
                <label for="phone">Phone *</label>
                <input type="tel" id="phone" name="phone" required placeholder="(202) 555-0123" />
              </div>
            </div>
            <div class="form-group">
              <label for="cubicles">Approximate Number of Cubicles/Workstations</label>
              <select id="cubicles" name="cubicles">
                <option value="">Select a range</option>
                <option value="1-20">1-20 workstations</option>
                <option value="21-50">21-50 workstations</option>
                <option value="51-75">51-75 workstations</option>
                <option value="76-100">76-100 workstations</option>
                <option value="100+">More than 100 workstations</option>
              </select>
            </div>
            <div class="form-group">
              <label for="details">Project Details</label>
              <textarea id="details" name="details" rows="4" placeholder="Tell us about your project: What's prompting the change? What are your goals? Any timeline considerations?"></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-submit">
              <span class="btn-text">Get Connected</span>
              <span class="btn-loading" style="display: none;">Sending...</span>
            </button>
          </form>
          <div id="form-success" class="form-success" style="display: none;">
            <div class="success-icon">&#10003;</div>
            <h3>Thank You!</h3>
            <p>Your request has been received. We'll be in touch soon to discuss your project.</p>
          </div>
        </div>
        <div class="contact-info">
          <div class="info-card">
            <h3>What to Expect</h3>
            <ul class="expect-list">
              <li>
                <span class="expect-number">1</span>
                <div>
                  <strong>We'll Be In Touch</strong>
                  <p>We'll reach out to discuss your project.</p>
                </div>
              </li>
              <li>
                <span class="expect-number">2</span>
                <div>
                  <strong>Project Discussion</strong>
                  <p>We'll understand your needs and situation.</p>
                </div>
              </li>
              <li>
                <span class="expect-number">3</span>
                <div>
                  <strong>Custom Plan</strong>
                  <p>Receive a reconfiguration plan with clear pricing.</p>
                </div>
              </li>
            </ul>
          </div>
          <div class="info-card highlight">
            <h3>Why Work With Us?</h3>
            <ul class="benefits-list">
              <li>
                <span class="check">&#10003;</span>
                Professional, experienced installers
              </li>
              <li>
                <span class="check">&#10003;</span>
                Works with any furniture situation
              </li>
              <li>
                <span class="check">&#10003;</span>
                Simple design services when you need them
              </li>
              <li>
                <span class="check">&#10003;</span>
                Now you can say "I have a guy"
              </li>
            </ul>
          </div>
          <div class="info-card">
            <h3>Service Areas</h3>
            <p class="areas-text">We serve businesses throughout the DC metro area:</p>
            <div class="areas-tags">
              <span>Washington DC</span>
              <span>Northern Virginia</span>
              <span>Maryland</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');
  const btnText = document.querySelector('.btn-text');
  const btnLoading = document.querySelector('.btn-loading');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (btnText && btnLoading) {
      (btnText as HTMLElement).style.display = 'none';
      (btnLoading as HTMLElement).style.display = 'inline';
    }

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    console.log('Form submission:', data);

    await new Promise(resolve => setTimeout(resolve, 1000));

    form.style.display = 'none';
    if (successMessage) {
      successMessage.style.display = 'block';
    }
  });
</script>

<style>
  .page-hero {
    padding: calc(var(--header-height) + 4rem) 0 4rem;
    background: linear-gradient(135deg, var(--color-bg-light) 0%, var(--color-bg) 100%);
    text-align: center;
  }

  .page-hero h1 {
    color: var(--color-secondary);
    margin-bottom: 1rem;
  }

  .page-hero p {
    color: var(--color-text-light);
    font-size: 1.25rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-section {
    background: var(--color-bg);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-form-wrapper {
    background: var(--color-bg-light);
    padding: 2.5rem;
    border-radius: 16px;
    border: 1px solid var(--color-border);
  }

  .form-header {
    margin-bottom: 2rem;
  }

  .form-header h2 {
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
  }

  .form-header p {
    color: var(--color-text-light);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 500;
    color: var(--color-text);
    font-size: 0.9375rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    margin-top: 0.5rem;
    width: 100%;
  }

  .form-success {
    text-align: center;
    padding: 2rem;
  }

  .success-icon {
    width: 64px;
    height: 64px;
    background: #d1fae5;
    color: var(--color-success);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 auto 1.5rem;
  }

  .form-success h3 {
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
  }

  .form-success p {
    color: var(--color-text-light);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    background: var(--color-bg-light);
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .info-card.highlight {
    background: var(--color-bg-alt);
    border-color: var(--color-primary);
  }

  .info-card h3 {
    color: var(--color-secondary);
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .expect-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .expect-list li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .expect-number {
    width: 28px;
    height: 28px;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .expect-list strong {
    color: var(--color-secondary);
    display: block;
    margin-bottom: 0.25rem;
  }

  .expect-list p {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    line-height: 1.4;
  }

  .benefits-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .benefits-list li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    color: var(--color-text);
    font-size: 0.9375rem;
  }

  .benefits-list .check {
    color: var(--color-success);
    font-weight: 700;
    flex-shrink: 0;
  }

  .areas-text {
    color: var(--color-text-light);
    font-size: 0.9375rem;
    margin-bottom: 0.75rem;
  }

  .areas-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .areas-tags span {
    padding: 0.375rem 0.75rem;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.875rem;
    border-radius: 50px;
    border: 1px solid var(--color-border);
  }

  @media (max-width: 968px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-info {
      order: -1;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }

  @media (max-width: 768px) {
    .contact-info {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .contact-form-wrapper {
      padding: 1.5rem;
    }
  }
</style>
