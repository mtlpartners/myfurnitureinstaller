---
interface Props {
  title: string;
  description: string;
  buttonText: string;
  buttonHref: string;
  variant?: 'primary' | 'light';
}

const { title, description, buttonText, buttonHref, variant = 'primary' } = Astro.props;
---

<section class={`cta-section ${variant}`}>
  <div class="container">
    <div class="cta-content">
      <h2>{title}</h2>
      <p>{description}</p>
      <a href={buttonHref} class={`btn ${variant === 'primary' ? 'btn-white' : 'btn-primary'}`}>
        {buttonText}
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 5rem 0;
  }

  .cta-section.primary {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
  }

  .cta-section.light {
    background: var(--color-bg-alt);
  }

  .cta-content {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-content h2 {
    margin-bottom: 1rem;
  }

  .cta-section.light .cta-content h2 {
    color: var(--color-secondary);
  }

  .cta-content p {
    margin-bottom: 2rem;
    font-size: 1.125rem;
    opacity: 0.9;
  }

  .cta-section.light .cta-content p {
    color: var(--color-text-light);
  }
</style>
