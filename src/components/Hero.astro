---
interface Props {
  title: string;
  subtitle: string;
  primaryCta?: {
    text: string;
    href: string;
  };
  secondaryCta?: {
    text: string;
    href: string;
  };
  image?: string;
  badge?: string;
}

const { title, subtitle, primaryCta, secondaryCta, image, badge } = Astro.props;
---

<section class="hero">
  <div class="hero-content container">
    <div class="hero-text">
      {badge && <span class="hero-badge">{badge}</span>}
      <h1>{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      <div class="hero-ctas">
        {primaryCta && (
          <a href={primaryCta.href} class="btn btn-primary">{primaryCta.text}</a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn btn-secondary">{secondaryCta.text}</a>
        )}
      </div>
      <div class="hero-trust">
        <div class="trust-item">
          <span class="trust-icon">&#10003;</span>
          <span>Professional, certified installers</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">&#10003;</span>
          <span>Simple design services</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">&#10003;</span>
          <span>DC, Virginia & Maryland</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      {image ? (
        <img src={image} alt="Office reconfiguration" loading="eager" />
      ) : (
        <div class="hero-placeholder">
          <div class="placeholder-grid">
            <div class="grid-item"></div>
            <div class="grid-item"></div>
            <div class="grid-item"></div>
            <div class="grid-item"></div>
            <div class="grid-item accent"></div>
            <div class="grid-item"></div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--header-height) + 4rem);
    padding-bottom: 4rem;
    background: linear-gradient(135deg, var(--color-bg-light) 0%, var(--color-bg) 100%);
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 50px;
    margin-bottom: 1.5rem;
  }

  .hero-text h1 {
    color: var(--color-secondary);
    margin-bottom: 1.5rem;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    line-height: 1.15;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .hero-trust {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-light);
    font-size: 0.9375rem;
  }

  .trust-icon {
    color: var(--color-success);
    font-weight: 700;
  }

  .hero-visual {
    position: relative;
  }

  .hero-visual img {
    border-radius: 16px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
  }

  .hero-placeholder {
    background: var(--color-bg-alt);
    border-radius: 16px;
    padding: 3rem;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 280px;
  }

  .grid-item {
    aspect-ratio: 1;
    background: var(--color-border);
    border-radius: 8px;
    transition: transform 0.3s ease;
  }

  .grid-item.accent {
    background: var(--color-primary);
  }

  .grid-item:hover {
    transform: scale(1.05);
  }

  @media (max-width: 968px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-ctas {
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-trust {
      align-items: center;
    }

    .hero-visual {
      order: -1;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: calc(var(--header-height) + 2rem);
    }

    .hero-ctas {
      flex-direction: column;
    }

    .hero-ctas .btn {
      width: 100%;
    }
  }
</style>
